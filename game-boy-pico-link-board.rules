
(rules PCB game-boy-pico-link-board.dsn
  (snap_angle 
    fortyfive_degree
  )
  (rule
    (width 500.0)
    (clearance 400.0)
    (clearance 250.0 (type smd_to_turn_gap))
    (clearance 100.0 (type smd))
    (clearance 400.0 (type "kicad_default"))
  )
  (padstack "Via[0-1]_800:400_um"
    (shape
      (circle F.Cu 800.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 800.0 0.0 0.0)
    )
    (attach off)
  )
  (via 
    "Via[0-1]_800:400_um" "Via[0-1]_800:400_um" default
  )
  (via 
    "Via[0-1]_800:400_um-kicad_default" "Via[0-1]_800:400_um" "kicad_default"
  )
  (via_rule
    default "Via[0-1]_800:400_um"
  )
  (via_rule
    "kicad_default" "Via[0-1]_800:400_um-kicad_default"
  )
  (class default
    (clearance_class default)
    (via_rule default)
    (rule
      (width 500.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
  (class "kicad_default"
    /GBVCC /SO /SI /SD /SC +3.3V VCCLOGIC +5V
    /PSC /PSI GND /PSO /PSD "unconnected-(U1-GPIO4-Pad6)" "unconnected-(U1-GPIO5-Pad7)" "unconnected-(U1-GPIO6-Pad9)"
    "unconnected-(U1-GPIO7-Pad10)" "unconnected-(U1-GPIO8-Pad11)" "unconnected-(U1-GPIO9-Pad12)" "unconnected-(U1-GPIO10-Pad14)" "unconnected-(U1-GPIO11-Pad15)" "unconnected-(U1-GPIO12-Pad16)" "unconnected-(U1-GPIO13-Pad17)" "unconnected-(U1-GPIO14-Pad19)"
    "unconnected-(U1-GPIO15-Pad20)" "unconnected-(U1-GPIO16-Pad21)" "unconnected-(U1-GPIO17-Pad22)" "unconnected-(U1-GPIO18-Pad24)" "unconnected-(U1-GPIO19-Pad25)" "unconnected-(U1-GPIO20-Pad26)" "unconnected-(U1-GPIO21-Pad27)" "unconnected-(U1-GPIO22-Pad29)"
    "unconnected-(U1-RUN-Pad30)" "unconnected-(U1-GPIO26_ADC0-Pad31)" "unconnected-(U1-GPIO27_ADC1-Pad32)" "unconnected-(U1-GPIO28_ADC2-Pad34)" "unconnected-(U1-ADC_VREF-Pad35)" "unconnected-(U1-3V3_EN-Pad37)" "unconnected-(U1-VSYS-Pad39)" "unconnected-(U1-GPIO5-Pad7)_1"
    "unconnected-(U1-GPIO6-Pad9)_1" "unconnected-(U1-GPIO19-Pad25)_1" "unconnected-(U1-GPIO28_ADC2-Pad34)_1" "unconnected-(U1-GPIO27_ADC1-Pad32)_1" "unconnected-(U1-VSYS-Pad39)_1" "unconnected-(U1-GPIO15-Pad20)_1" "unconnected-(U1-ADC_VREF-Pad35)_1" "unconnected-(U1-GPIO8-Pad11)_1"
    "unconnected-(U1-RUN-Pad30)_1" "unconnected-(U1-GPIO13-Pad17)_1" "unconnected-(U1-GPIO12-Pad16)_1" "unconnected-(U1-GPIO16-Pad21)_1" "unconnected-(U1-GPIO18-Pad24)_1" "unconnected-(U1-GPIO14-Pad19)_1" "unconnected-(U1-GPIO4-Pad6)_1" "unconnected-(U1-GPIO22-Pad29)_1"
    "unconnected-(U1-GPIO20-Pad26)_1" "unconnected-(U1-GPIO7-Pad10)_1" "unconnected-(U1-GPIO11-Pad15)_1" "unconnected-(U1-3V3_EN-Pad37)_1" "unconnected-(U1-GPIO26_ADC0-Pad31)_1" "unconnected-(U1-GPIO17-Pad22)_1" "unconnected-(U1-GPIO9-Pad12)_1" "unconnected-(U1-GPIO10-Pad14)_1"
    "unconnected-(U1-GPIO21-Pad27)_1"
    (clearance_class "kicad_default")
    (via_rule "kicad_default")
    (rule
      (width 500.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
)